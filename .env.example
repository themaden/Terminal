# ─────────────────────────────────────────────────────────────────
# JetNexus AI — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# ⚠️  NEVER commit the real .env file to version control!
# ─────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jetnexus
POSTGRES_USER=jetnexus
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql+asyncpg://jetnexus:CHANGE_ME_strong_password_here@localhost:5432/jetnexus

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FLIGHT_EVENTS_TOPIC=flight-events
KAFKA_NOTIFICATION_TOPIC=notifications
KAFKA_CONSUMER_GROUP=jetnexus-decision

# ── AI / LLM ───────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Twilio (SMS / WhatsApp) ────────────────────────────────────
# Get credentials at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC_REPLACE_WITH_YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_TWILIO_TOKEN
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX

# ── Application Settings ───────────────────────────────────────
APP_NAME=JetNexus AI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
DECISION_ENGINE_URL=http://localhost:8000
NOTIFICATION_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_URL=http://localhost:8002

# ── Security ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
AES_ENCRYPTION_KEY=CHANGE_ME_generate_with_secrets_token_hex_16
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_32

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
