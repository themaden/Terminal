# ─────────────────────────────────────────────
# Aero-Agent Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database (PostgreSQL) ──────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aeroagent
POSTGRES_USER=aeroagent
POSTGRES_PASSWORD=aeroagent_secret_2024
DATABASE_URL=postgresql+asyncpg://aeroagent:aeroagent_secret_2024@localhost:5432/aeroagent

# ── Redis ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FLIGHT_EVENTS_TOPIC=flight-events
KAFKA_NOTIFICATION_TOPIC=notifications
KAFKA_CONSUMER_GROUP=aero-agent-decision

# ── AI / LLM ──────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Twilio (SMS / WhatsApp) ────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Application Settings ──────────────────
APP_NAME=Aero-Agent
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
DECISION_ENGINE_URL=http://localhost:8000
NOTIFICATION_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_URL=http://localhost:8002

# ── Security ──────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
API_KEY=aero-agent-api-key-dev

# ── CORS ──────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Logging ───────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
