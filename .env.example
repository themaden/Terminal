# ═══════════════════════════════════════════════════════════════
# JetNexus AI — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
#
#  KULLANIM:
#  1. Bu dosyayı kopyala:  cp .env.example .env    (Mac/Linux)
#                          copy .env.example .env  (Windows)
#  2. .env dosyasını aç ve gerçek değerleri doldur
#  3. .env dosyasını asla GitHub'a yükleme!
#
#  Bu dosya (.env.example) güvenlidir — içinde gerçek şifre yok.
# ═══════════════════════════════════════════════════════════════

# ── VERİTABANI (PostgreSQL) ────────────────────────────────────
# Docker otomatik oluşturur. Güçlü bir şifre belirle.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jetnexus
POSTGRES_USER=jetnexus
POSTGRES_PASSWORD=BURAYA_GUCLU_SIFRE_YAZ_min12karakter
DATABASE_URL=postgresql+asyncpg://jetnexus:BURAYA_GUCLU_SIFRE_YAZ_min12karakter@localhost:5432/jetnexus

# ── REDIS (Önbellek) ───────────────────────────────────────────
# Docker otomatik başlatır. Değiştirmene gerek yok.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── KAFKA (Mesaj Kuyruğu) ──────────────────────────────────────
# Docker otomatik başlatır. Değiştirmene gerek yok.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FLIGHT_EVENTS_TOPIC=flight-events
KAFKA_NOTIFICATION_TOPIC=notifications
KAFKA_CONSUMER_GROUP=jetnexus-decision

# ── OPENAI API — ZORUNLU ───────────────────────────────────────
# Nereden alınır: https://platform.openai.com/api-keys
# → Sağ üst köşe → "Create new secret key" → Kopyala
OPENAI_API_KEY=sk-proj-BURAYA_OPENAI_API_KEYINI_YAPISTIR
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── TWILIO SMS/WhatsApp — İSTEĞE BAĞLI ───────────────────────
# Nereden alınır: https://console.twilio.com
# → Dashboard → Account Info → Account SID & Auth Token
# Not: Twilio olmadan sistem SMS göndermez ama çalışmaya devam eder.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── GÜVENLİK ANAHTARLARI — ZORUNLU ───────────────────────────
#
# SECRET_KEY üret (terminalde çalıştır):
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_URET_python_secrets_token_hex_32
#
# AES_ENCRYPTION_KEY üret (terminalde çalıştır):
#   python -c "import secrets; print(secrets.token_hex(16))"
AES_ENCRYPTION_KEY=BURAYA_URET_python_secrets_token_hex_16
#
# API_KEY üret (terminalde çalıştır):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=BURAYA_URET_python_secrets_token_urlsafe_32

# ── UYGULAMA AYARLARI ─────────────────────────────────────────
APP_NAME=JetNexus AI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
DECISION_ENGINE_URL=http://localhost:8000
NOTIFICATION_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_URL=http://localhost:8002

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── LOGLAMA ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
