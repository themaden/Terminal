# ═══════════════════════════════════════════════════════════════════════════════
# JetNexus AI — .env.example  (şablon dosya, güvenlidir)
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Bu dosya NEDIR?
#  ────────────────
#  Projedeki tüm ayarların şablonudur. İçinde gerçek şifre yoktur.
#  GitHub'a yüklenebilir — başkası projeyi klonladığında ne doldurması
#  gerektiğini görür.
#
#  .env dosyası NEDIR?
#  ────────────────────
#  Gerçek değerlerin (şifreler, API key'leri) tutulduğu dosyadır.
#  .gitignore ile GitHub'a yüklenmesi engellenir — sadece senin bilgisayarında
#  bulunur. Bu dosyayı kimseyle paylaşma.
#
#  NASIL KULLANILIR?
#  ──────────────────
#  Windows: copy .env.example services\decision-engine\.env
#  Mac/Linux: cp .env.example services/decision-engine/.env
#  Sonra .env dosyasını aç → "BURAYA_..." yazan yerleri doldur.
#
# ═══════════════════════════════════════════════════════════════════════════════


# ── VERİTABANI ─────────────────────────────────────────────────────────────────
# Lokal geliştirme için SQLite yeterli — değiştirmene gerek yok
DATABASE_URL=sqlite+aiosqlite:///aeroagent.sqlite3
APP_DEBUG=true

# İleride PostgreSQL'e geçmek istersen:
# DATABASE_URL=postgresql+asyncpg://jetnexus:SIFRE@localhost:5432/jetnexus


# ── GÜVENLİK ───────────────────────────────────────────────────────────────────
# Üretmek için terminalde çalıştır:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_URET_python_secrets_token_hex_32
AES_ENCRYPTION_KEY=BURAYA_URET_python_secrets_token_hex_16
JWT_EXPIRE_MINUTES=480


# ═══════════════════════════════════════════════════════════════════════════════
# DIŞ SERVİS API KEY'LERİ
# Her biri isteğe bağlıdır — boş bırakırsan sistem mock veri ile çalışır.
# ═══════════════════════════════════════════════════════════════════════════════

# ── 1. OPENAI — AI karar motoru ────────────────────────────────────────────────
# NEREDEN : https://platform.openai.com/api-keys
# ADIMLAR : Kayıt ol → Sağ üst profil → "API Keys" → "Create new secret key"
# FİYAT   : Yeni hesaba $5 ücretsiz kredi (GPT-4o ile ~50 kriz analizi)
# BOŞSA   : Sistem kural tabanlı karar üretir (Ollama varsa onu kullanır)
OPENAI_API_KEY=sk-proj-BURAYA_OPENAI_KEY_YAPISTIR
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── 2. OLLAMA — Yerel ücretsiz LLM (Llama 3.2) ─────────────────────────────────
# NEREDEN : https://ollama.com/download  →  ücretsiz, internet gerekmez
# ADIMLAR : Ollama'yı kur → terminalde: ollama pull llama3.2
# FİYAT   : Tamamen ücretsiz, veriler bilgisayarında kalır
# BOŞSA   : OpenAI yoksa kural tabanlı karar devreye girer
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── 3. AMADEUS PSS — Uçuş arama & rezervasyon ──────────────────────────────────
# NEREDEN : https://developers.amadeus.com
# ADIMLAR : "Get started for free" → Kayıt ol (kredi kartı yok)
#           → My Apps → "Create new app" → Self-Service
#           → Client ID ve Client Secret kopyala
# FİYAT   : Sandbox tamamen ücretsiz, 2.000 istek/ay
# BOŞSA   : Sistem mock uçuş verisi döner (yine çalışır)
AMADEUS_CLIENT_ID=BURAYA_AMADEUS_CLIENT_ID_YAPISTIR
AMADEUS_CLIENT_SECRET=BURAYA_AMADEUS_CLIENT_SECRET_YAPISTIR

# ── 4. CİRİUM — Gerçek zamanlı AODB uçuş verisi ────────────────────────────────
# NEREDEN : https://developer.cirium.com
# ADIMLAR : Sign Up Free → Dashboard → App ID + App Key
# FİYAT   : Free trial 500 istek/gün
#
# DAHA KOLAY ALTERNATİF → AviationStack:
# NEREDEN : https://aviationstack.com
# ADIMLAR : "Get Free API Key" → E-posta ile kayıt → API Key kopyala
# FİYAT   : 500 istek/ay ücretsiz, kredi kartı yok
# BOŞSA   : Sistem simüle edilmiş kalkış/varış verisi kullanır
CIRIUM_APP_ID=BURAYA_CIRIUM_VEYA_AVIATIONSTACK_KEY_YAPISTIR
CIRIUM_APP_KEY=BURAYA_CIRIUM_APP_KEY_YAPISTIR


# ── UYGULAMA ───────────────────────────────────────────────────────────────────
APP_NAME=JetNexus AI
APP_ENV=development
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
LOG_LEVEL=INFO
