# ═══════════════════════════════════════════════════════════════════════════════
# JetNexus AI — .env.example  (ŞABLON DOSYA — GitHub'a yüklenebilir)
# ═══════════════════════════════════════════════════════════════════════════════
#
#  BU DOSYA NEDİR?
#  ───────────────
#  Projenin ihtiyaç duyduğu tüm ortam değişkenlerinin şablonudur.
#  İçinde gerçek şifre veya API key YOKTUR — güvenlidir.
#
#  .env DOSYASI NEDİR?
#  ───────────────────
#  Gerçek şifrelerin ve API key'lerinin tutulduğu dosyadır.
#  .gitignore sayesinde GitHub'a asla yüklenmez.
#  Sadece senin bilgisayarında bulunur.
#
#  NASIL KURULUR?
#  ──────────────
#  Windows : copy .env.example .env
#  Mac/Linux: cp .env.example .env
#  Sonra .env dosyasını aç → "BURAYA_..." yazan yerleri doldur.
#
# ═══════════════════════════════════════════════════════════════════════════════
#
#  PROJEDE KULLANILAN DEĞİŞKENLER (kodda doğrulanan):
#
#  #  Değişken                Kullanıldığı Dosya                  Zorunlu?
#  ─  ──────────────────────  ──────────────────────────────────  ────────
#  1  DATABASE_URL            app/db/database.py                  EVET
#  2  APP_NAME/ENV/VERSION    app/main.py                         EVET
#  3  APP_DEBUG               app/main.py, db/database.py         EVET
#  4  SECRET_KEY              app/core/security.py (JWT)          EVET
#  5  AES_ENCRYPTION_KEY      app/utils/crypto.py                 EVET
#  6  JWT_EXPIRE_MINUTES      app/core/security.py                EVET
#  7  OPENAI_API_KEY          app/agents/coordinator.py           İsteğe bağlı
#  8  LLM_MODEL/TEMP/TOKENS   app/agents/coordinator.py           İsteğe bağlı
#  9  OLLAMA_BASE_URL/MODEL   app/agents/coordinator.py           İsteğe bağlı
#  10 AMADEUS_CLIENT_ID/SEC   app/integrations/amadeus/           İsteğe bağlı
#  11 CIRIUM_APP_ID/KEY       app/integrations/cirium/            İsteğe bağlı
#  12 CORS_ORIGINS            app/main.py                         EVET
#  13 NEXT_PUBLIC_API_URL     frontend/src/lib/api.ts             EVET
#
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 1. VERİTABANI  [ZORUNLU — değiştirme]
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///aeroagent.sqlite3


# ─────────────────────────────────────────────────────────────────────────────
# 2. UYGULAMA AYARLARI  [ZORUNLU — değiştirme]
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=JetNexus AI
APP_ENV=development
APP_VERSION=1.0.0
APP_DEBUG=true


# ─────────────────────────────────────────────────────────────────────────────
# 3. GÜVENLİK  [ZORUNLU — kendi değerini üret]
# ─────────────────────────────────────────────────────────────────────────────
# SECRET_KEY → JWT token imzalamada kullanılır
# Üret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_URET_python_secrets_token_hex_32
#
# AES_ENCRYPTION_KEY → yolcu verisi şifrelemesinde kullanılır
# Üret: python -c "import secrets; print(secrets.token_hex(16))"
AES_ENCRYPTION_KEY=BURAYA_URET_python_secrets_token_hex_16
#
JWT_EXPIRE_MINUTES=480


# ─────────────────────────────────────────────────────────────────────────────
# 4. OPENAI API KEY  [İSTEĞE BAĞLI]
# ─────────────────────────────────────────────────────────────────────────────
# Nereden : https://platform.openai.com/api-keys
# Adımlar : Kayıt ol → Sol menü "API Keys" → "Create new secret key"
# Fiyat   : Yeni hesaba $5 ücretsiz kredi (~50 kriz analizi)
# Boşsa   : Ollama/Llama 3.2 devreye girer → o da yoksa kural tabanlı
OPENAI_API_KEY=sk-proj-BURAYA_OPENAI_KEY_YAPISTIR
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096


# ─────────────────────────────────────────────────────────────────────────────
# 5. OLLAMA / LLAMA 3.2  [İSTEĞE BAĞLI — Yerel, Tamamen Ücretsiz]
# ─────────────────────────────────────────────────────────────────────────────
# Nereden : https://ollama.com/download (API key gerekmez)
# Adımlar : 1. Ollama'yı kur  2. Terminalde: ollama pull llama3.2
# Fiyat   : Tamamen ücretsiz, veriler bilgisayarında kalır
# Boşsa   : Kural tabanlı karar üretilir
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2


# ─────────────────────────────────────────────────────────────────────────────
# 6. AMADEUS PSS  [İSTEĞE BAĞLI]
# ─────────────────────────────────────────────────────────────────────────────
# Nereden : https://developers.amadeus.com
# Adımlar : "Get started for free" → My Apps → Create new app → Self-Service
#           → Client ID ve Client Secret'ı kopyala
# Fiyat   : Sandbox tamamen ücretsiz, 2.000 istek/ay
# Boşsa   : Sistem mock uçuş verisi döner, yine çalışır
AMADEUS_CLIENT_ID=BURAYA_AMADEUS_CLIENT_ID_YAPISTIR
AMADEUS_CLIENT_SECRET=BURAYA_AMADEUS_CLIENT_SECRET_YAPISTIR


# ─────────────────────────────────────────────────────────────────────────────
# 7. CIRIUM / AODB  [İSTEĞE BAĞLI]
# ─────────────────────────────────────────────────────────────────────────────
# KOLAY (önerilir) → AviationStack:
#   Nereden : https://aviationstack.com → "Get Free API Key"
#   Fiyat   : 500 istek/ay ücretsiz, kredi kartı yok
#
# GELİŞMİŞ → Cirium:
#   Nereden : https://developer.cirium.com → Sign Up Free
#   Fiyat   : 500 istek/gün ücretsiz
#
# Boşsa   : Simüle uçuş verisi kullanılır, yine çalışır
CIRIUM_APP_ID=BURAYA_AVIATIONSTACK_VEYA_CIRIUM_KEY_YAPISTIR
CIRIUM_APP_KEY=BURAYA_CIRIUM_APP_KEY_YAPISTIR


# ─────────────────────────────────────────────────────────────────────────────
# 8. FRONTEND  [ZORUNLU — değiştirme]
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000


# ─────────────────────────────────────────────────────────────────────────────
# 9. CORS  [ZORUNLU — değiştirme]
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
