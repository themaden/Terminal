# ═══════════════════════════════════════════════════════════════════════════════
# JetNexus AI — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
#
#  KULLANIM:
#  1. Bu dosyayı kopyala:
#       Windows → copy .env.example services\decision-engine\.env
#       Mac/Linux → cp .env.example services/decision-engine/.env
#  2. .env dosyasını aç ve "BURAYA_..." yazan yerleri gerçek değerlerle doldur
#  3. .env dosyasını ASLA GitHub'a yükleme! (.gitignore'da engellidir)
#
#  Bu dosya (.env.example) güvenlidir — içinde gerçek şifre yok.
# ═══════════════════════════════════════════════════════════════════════════════


# ── VERİTABANI ─────────────────────────────────────────────────────────────────
# Lokal geliştirme → SQLite (Docker gerekmez, her şey tek dosyada)
DATABASE_URL=sqlite+aiosqlite:///aeroagent.sqlite3

# Production → PostgreSQL (Docker Compose ile otomatik ayağa kalkar)
# DATABASE_URL=postgresql+asyncpg://jetnexus:SIFRE@localhost:5432/jetnexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jetnexus
POSTGRES_USER=jetnexus
POSTGRES_PASSWORD=BURAYA_GUCLU_SIFRE_YAZ


# ── REDIS (önbellek & oturum) ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0


# ── KAFKA (uçuş event akışı) ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FLIGHT_EVENTS_TOPIC=flight-events
KAFKA_NOTIFICATION_TOPIC=notifications
KAFKA_CONSUMER_GROUP=jetnexus-decision


# ═══════════════════════════════════════════════════════════════════════════════
#  DIŞ SERVİS ENTEGRASYONLARİ
#  Her biri opsiyonel — key yoksa sistem mock veri ile çalışmaya devam eder
# ═══════════════════════════════════════════════════════════════════════════════


# ── 1. OPENAI API — AI Karar & Koordinasyon Motoru ─────────────────────────────
#
#  NEREDEN ALINIR:
#    https://platform.openai.com/api-keys
#    → Giriş yap → Sağ üst profil → "API Keys" → "Create new secret key"
#
#  FİYAT:
#    Yeni hesaplara $5 ücretsiz kredi → GPT-4o ile ~50 kriz analizi için yeterli
#    Sonrası: GPT-4o ≈ $5 / 1M token (çok ucuz)
#
#  NOT: Key yoksa AI agent'lar kural tabanlı karar üretir (yine çalışır)
#
OPENAI_API_KEY=sk-proj-BURAYA_OPENAI_KEY_YAPISTIR
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096


# ── 2. AMADEUS PSS — Uçuş Arama, Rezervasyon, PNR ─────────────────────────────
#
#  NEREDEN ALINIR:
#    https://developers.amadeus.com
#    → "Get started for free" → Ücretsiz kayıt ol (kredi kartı lazım değil)
#    → Dashboard → "My Apps" → "Create new app" → "Self-Service" seç
#    → Client ID ve Client Secret'ı kopyala
#
#  FİYAT:
#    Self-Service Sandbox: TAMAMEN ÜCRETSİZ, limit: 2.000 istek/ay
#    Production (Enterprise): Amadeus ile sözleşme gerekir
#
#  API'LAR:
#    - Flight Offers Search (uçuş arama)
#    - Flight Price (fiyatlama)
#    - Flight Create Orders (rezervasyon)
#    - Schedule (tarifeli uçuş verileri)
#
#  NOT: Sandbox'ta gerçekçi mock veri döner (gerçek rezervasyon yapılmaz)
#       Key yoksa sistem kendi mock verisini kullanır
#
AMADEUS_CLIENT_ID=BURAYA_AMADEUS_CLIENT_ID_YAPISTIR
AMADEUS_CLIENT_SECRET=BURAYA_AMADEUS_CLIENT_SECRET_YAPISTIR


# ── 3. CİRİUM FlightStats — Gerçek Zamanlı AODB Uçuş Verisi ────────────────────
#
#  NEREDEN ALINIR:
#    https://developer.cirium.com
#    → "Sign Up Free" → Dashboard → "My Apps" → Uygulama oluştur
#    → App ID ve App Key'i kopyala
#
#  ALTERNATİF (daha kolay):
#    https://aviationstack.com
#    → Ücretsiz plan: 500 istek/ay, kredi kartı gerektirmez
#    → API Key alınca: CIRIUM_APP_ID=aviationstack, CIRIUM_APP_KEY=senin_key
#
#  FİYAT (Cirium):
#    Free Trial: 500 istek/gün (kredi kartı gerekmez)
#    Sonrası: kurumsal fiyat (ortalama $200+/ay)
#
#  FİYAT (AviationStack - önerilen başlangıç):
#    Free: 500 istek/ay
#    Starter: $9.99/ay → 10.000 istek
#
#  NOT: Key yoksa sistem simüle edilmiş kalkış/varış verisi kullanır
#
CIRIUM_APP_ID=BURAYA_CIRIUM_APP_ID_YAPISTIR
CIRIUM_APP_KEY=BURAYA_CIRIUM_APP_KEY_YAPISTIR


# ── 4. TWILIO — SMS & WhatsApp Yolcu Bildirimi ─────────────────────────────────
#
#  NEREDEN ALINIR:
#    https://console.twilio.com
#    → "Sign up for free" → Dashboard'da Account SID ve Auth Token görünür
#    → SMS için: Phone Numbers → Buy a number (trial'da ücretsiz bir numara verilir)
#    → WhatsApp için: Messaging → Try WhatsApp → Sandbox kullan
#
#  FİYAT:
#    Trial hesap: $15 ücretsiz kredi → ~150 SMS gönderebilirsin
#    Sonrası: SMS ≈ $0.0079/mesaj (Türkiye'ye ~$0.05)
#
#  NOT: Twilio yoksa sistem çalışmaya devam eder, yolcu bildirimleri loglanır
#       ama SMS/WhatsApp gönderilmez
#
TWILIO_ACCOUNT_SID=BURAYA_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=BURAYA_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886


# ═══════════════════════════════════════════════════════════════════════════════
#  GÜVENLİK ANAHTARLARI — ZORUNLU (üret, değiştir, sakla)
# ═══════════════════════════════════════════════════════════════════════════════
#
#  SECRET_KEY üret (terminalde):
#    python -c "import secrets; print(secrets.token_hex(32))"
#
#  AES_ENCRYPTION_KEY üret (terminalde):
#    python -c "import secrets; print(secrets.token_hex(16))"
#
#  API_KEY üret (terminalde):
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
SECRET_KEY=BURAYA_URET_python_secrets_token_hex_32
AES_ENCRYPTION_KEY=BURAYA_URET_python_secrets_token_hex_16
API_KEY=BURAYA_URET_python_secrets_token_urlsafe_32
JWT_EXPIRE_MINUTES=480


# ── UYGULAMA AYARLARI ──────────────────────────────────────────────────────────
APP_NAME=JetNexus AI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
DECISION_ENGINE_URL=http://localhost:8000
NOTIFICATION_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_URL=http://localhost:8002


# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000


# ── LOGLAMA ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
