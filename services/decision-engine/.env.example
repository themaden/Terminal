# ═══════════════════════════════════════════════════════════════════════════════
# JetNexus AI — Backend Environment Variables Template
# Kopyala: cp .env.example .env  →  değerleri doldur
# ═══════════════════════════════════════════════════════════════════════════════

# ── VERİTABANI ─────────────────────────────────────────────────────────────────
# Geliştirme (SQLite, Docker gerekmez):
DATABASE_URL=sqlite+aiosqlite:///aeroagent.sqlite3

# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://jetnexus:SIFRE@localhost:5432/jetnexus

# ── REDIS ──────────────────────────────────────────────────────────────────────
# Geliştirme (yerel Redis):
REDIS_URL=redis://localhost:6379/0
# Docker Compose içinde:
# REDIS_URL=redis://redis:6379/0

# ── GÜVENLİK ───────────────────────────────────────────────────────────────────
# Üret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── UYGULAMA ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# ── LLM (isteğe bağlı) ────────────────────────────────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o

# ── AMADEUS PSS (sandbox → production için gerçek credentials gerekir) ─────────
AMADEUS_CLIENT_ID=sandbox_client_id
AMADEUS_CLIENT_SECRET=sandbox_client_secret

# ── BİLDİRİM SERVİSİ ──────────────────────────────────────────────────────────
NOTIFICATION_SERVICE_URL=http://localhost:8001
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
